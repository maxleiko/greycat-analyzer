{
  "name": "greycat-analyzer-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm": "./scripts/build-wasm.sh --out-dir packages/analyzer/wasm",
    "wasm:playground": "./playground/scripts/build-wasm.sh",
    "build:packages": "pnpm --filter \"@greycat/*\" run build",
    "check:packages": "pnpm --filter \"@greycat/*\" run check"
  },
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
