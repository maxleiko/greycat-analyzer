// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "request": "launch",
    "adapter": "CodeLLDB",
    "label": "Debug fmt",
    "program": "${ZED_WORKTREE_ROOT}/target/debug/greycat-analyzer",
    "args": ["fmt", "project.gcl"],
    "build": {
      "label": "Build greycat-analyzer",
      "command": "cargo",
      "args": ["build", "--package", "greycat-analyzer"],
      "use_new_terminal": false,
      "allow_concurrent_runs": false,
      "reveal": "always",
      "reveal_target": "dock",
      "hide": "never",
      "shell": "system",
      "show_summary": false,
      "show_command": false,
      "save": "none",
      "hooks": []
    },
    "sourceLanguages": ["rust"]
  }
]
