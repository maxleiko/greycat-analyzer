{
  "name": "greycat-analyzer",
  "version": "0.1.0",
  "main": "extension.js",
  "description": "GreyCat language support for Visual Studio Code",
  "author": "Maxime Tricoire <max.tricoire@gmail.com>",
  "license": "MIT",
  "publisher": "maxleiko",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxleiko/greycat-analyzer"
  },
  "scripts": {
    "clean": "rm -f extension.js",
    "build": "node scripts/build.mjs",
    "vscode:install": "code --install-extension greycat-analyzer.vsix"
  },
  "activationEvents": [
    "workspaceContains:project.gcl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "greycat",
        "aliases": ["GreyCat", "Greycat", "greycat", "gcl"],
        "extensions": [".gcl"],
        "configuration": "./grammar/language-configuration.json",
        "icon": {
          "light": "./icons/light/gcl.svg",
          "dark": "./icons/dark/gcl.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "greycat",
        "scopeName": "source.gcl",
        "path": "./grammar/Greycat.tmLanguage",
        "embeddedLanguages": {
          "source.md": "markdown",
          "meta.embedded.doc.gcl": "markdown"
        }
      }
    ],
    "snippets": [
      {
        "language": "greycat",
        "path": "./snippets/snippets.json"
      }
    ],
    "commands": [
      {
        "command": "greycat-analyzer.restart",
        "title": "greycat-analyzer: restart"
      }
    ],
    "configurationDefaults": {
      "[greycat]": {
        "editor.defaultFormatter": "maxleiko.greycat-analyzer"
      }
    }
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "dependencies": {
    "vscode-languageclient": "9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.4.2",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3"
  }
}