{
  "compilerOptions": {
    "rootDir": "src",
    "module": "CommonJS",
    "target": "ES2020",
    "lib": ["ES2020"],
    "noEmit": true,

    "strict": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": ["node_modules", ".vscode-test"]
}
