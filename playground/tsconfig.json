{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "lib": ["ES2023", "DOM"],
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Lit 3 uses legacy TS decorators (@customElement / @property / @state). */
    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Resolve @greycat/* to source so the TS server (in editors and
       `vp check`) doesn't require a prior `pnpm build:packages` to
       find the types. Mirrors `vite.config.ts`'s `resolve.alias`. */
    "paths": {
      "@greycat/analyzer": ["../packages/analyzer/src/index.ts"],
      "@greycat/monaco": ["../packages/monaco/src/index.ts"]
    }
  },
  "include": ["src"]
}
